# ============================================
# Environment Variables Template
# Copy this file to .env and fill in values
# cp .env.example .env
# ============================================

# --- Project ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database ---
# PostgreSQL connection string (e.g. Neon, Supabase, Railway)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# --- Authentication ---
# Clerk (https://clerk.com) or your auth provider
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Payments (if applicable) ---
# Asaas (https://asaas.com) — Brazilian payment gateway
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=

# Stripe (https://stripe.com) — International payment gateway
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Maps / Geolocation (if applicable) ---
# Google Maps — Enable Routes API + Geocoding API in Cloud Console
# GOOGLE_MAPS_API_KEY=

# --- File Upload (if applicable) ---
# UploadThing (https://uploadthing.com)
# UPLOADTHING_TOKEN=

# --- MCP Tools (AI Development) ---
# PageSpeed Insights API — Get free key at https://console.cloud.google.com/apis/credentials
# Enable "PageSpeed Insights API" at https://console.cloud.google.com/apis/library
PAGESPEED_API_KEY=

# Tavily Search API — Get key at https://tavily.com
TAVILY_API_KEY=

# --- Optional MCP Providers ---
# Neon MCP (https://neon.tech) — Direct database management
# NEON_API_KEY=

# Supabase MCP (https://supabase.com) — Supabase management
# SUPABASE_ACCESS_TOKEN=
